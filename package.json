{
  "name": "metricyak",
  "private": true,
  "version": "0.0.0",
  "description": "A developer first platform using metrics that come through webhooks or other sources to trigger workflow automations",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "yak": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": ">=22.0.0"
  }
}
