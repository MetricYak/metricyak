# PostgreSQL connection string. Must be a credentialed postgres:// URL.
# Matches the docker-compose service (user/password/db all "metricyak").
DATABASE_URL=postgres://metricyak:metricyak@localhost:5432/metricyak

# Process events in-process without Redis (recommended for local dev).
RUN_WORKER_INLINE=true

# Required only when RUN_WORKER_INLINE is not set:
# REDIS_URL=redis://localhost:6379

# Optional:
# PORT=3000
# WORKER_CONCURRENCY=1

# ClickHouse (analytical store) — matches the docker-compose clickhouse service
CLICKHOUSE_URL=http://metricyak:metricyak@localhost:8123/metricyak

# Kafka (streaming backbone) — matches the docker-compose kafka service's external listener.
# This app runs on the host (`pnpm dev`), so it reaches Kafka via the port docker-compose
# publishes to localhost.
KAFKA_BROKERS=localhost:9092

# ClickHouse's own Kafka consumer (its Kafka Engine table) runs *inside* the Docker network,
# not on the host — it must use the docker-compose internal listener (the "kafka" service name),
# not localhost. Optional: defaults to KAFKA_BROKERS if unset, which is only correct when this
# app is also running inside the same Docker network as Kafka (e.g. a fully-containerized deploy).
CLICKHOUSE_KAFKA_BROKERS=kafka:29092
