{
  "name": "@metricyak/queue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "chokidar \"src/**/*.ts\" tsconfig.json -c \"tsc && tsc-alias\" --initial",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "@metricyak/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "chokidar-cli": "^3.0.0",
    "tsc-alias": "^1.9.1",
    "typescript": "catalog:"
  }
}
