{
  "name": "@metricyak/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "BullMQ worker for processing MetricYak jobs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
